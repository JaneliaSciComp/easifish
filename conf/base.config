/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    JaneliaSciComp/easifish Nextflow base config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Runs in `local` mode - all jobs will be run on the logged in environment.
----------------------------------------------------------------------------------------
*/

process {

    // Defaults for all processes
    cpus   = { params.check_max( 1    * task.attempt, 'cpus', params ) }
    memory = { params.check_max( 6.GB * task.attempt, 'memory', params ) }
    time   = { params.check_max( 4.h  * task.attempt, 'time', params ) }

    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // Process-specific resource requirements
    withLabel:process_single {
        cpus   = 1
        memory = { params.check_max( 6.GB * task.attempt, 'memory', params) }
        time   = { params.check_max( 4.h  * task.attempt, 'time', params) }
    }
    withLabel:process_low {
        cpus   = { params.check_max( 2     * task.attempt, 'cpus', params ) }
        memory = { params.check_max( 12.GB * task.attempt, 'memory', params ) }
        time   = { params.check_max( 4.h   * task.attempt, 'time', params) }
    }
    withLabel:process_medium {
        cpus   = { params.check_max( 6     * task.attempt, 'cpus', params ) }
        memory = { params.check_max( 36.GB * task.attempt, 'memory', params ) }
        time   = { params.check_max( 8.h   * task.attempt, 'time', params ) }
    }
    withLabel:process_high {
        cpus   = { params.check_max( 12    * task.attempt, 'cpus', params ) }
        memory = { params.check_max( 72.GB * task.attempt, 'memory', params ) }
        time   = { params.check_max( 16.h  * task.attempt, 'time', params ) }
    }
    withLabel:process_long {
        time   = { params.check_max( 24.h  * task.attempt, 'time', params ) }
    }
    withLabel:process_high_memory {
        memory = { params.check_max( 200.GB * task.attempt, 'memory', params ) }
    }
    withLabel:error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
}
