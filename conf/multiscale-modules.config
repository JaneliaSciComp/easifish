params {
    skip_multiscale_warped_image   = false
    multiscale_cpus                = 1
    multiscale_mem_gb              = 15
    preserve_anisotropy            = true
}

process {

    withName:"(.*)?MULTISCALE.*:.*" {
        // all processes that run as part of the multiscale workflow
        // use this container
        container = 'ghcr.io/janeliascicomp/zarr-tools:0.3.0-dask2025.11.0-py12-ol9'
    }

    withName:"(.*)?MULTISCALE.*:MULTISCALE_PYRAMID" {
        time = 8.h

        ext.args = [
            params.preserve_anisotropy ? '--preserve-anisotropy' : '',
        ].join(' ')
    }

}
