params {
    runtime_opts                       = ''

    segmentation_ids                   = null
    segmentation_input                 = ''
    segmentation_subpaths              = ''
    seg_channels                       = ''
    seg_scales                         = '2'
    segmentation_subdir                = 'segmentation'
    segmentation_imgname               = 'segmentation.zarr'

    run_segmentation                   = true
    skip_cellpose_merge_labels         = false
    run_standalone_merge_labels        = false
    run_segmentation_multiscale        = false
    distributed_cellpose               = true
    cellpose_model                     = 'cpsam'
    cellpose_models_dir                = ''
    cellpose_mask                      = ''
    cellpose_mask_subpath              = ''
    cellpose_log_config                = "${projectDir}/conf/cellpose_logging_config.ini"
    cellpose_dask_config               = "${projectDir}/conf/dask_config.yml"

    sample_anisotropy                  = 0
    sample_expansion_factor            = 1.0
    sample_voxel_spacing               = ''
    sample_timeindex                   = ''
    sample_z_axis                      = ''
    sample_channel_axis                = ''

    segmentation_processsize           = '256,256,256'
    segmentation_process_overlap       = ''
    segmentation_roi                   = ''
    segmentation_compression           = 'zstd'
    segmentation_compression_opts      = '\'{"level": 5}\''
    segmentation_zarr_format           = 3
    segmentation_zarr_sharding_factor  = ''
    segmentation_output_chunksize      = ''
    cellpose_use_gpu                   = true
    cellpose_device                    = '0'

    cellpose_do_3D                     = true
    cellpose_verbose                   = false
    cellpose_diameter                  = '30'
    cellpose_no_resampling             = false
    cellpose_inference_batch_size      = 8
    cellpose_min_size                  = 5
    cellpose_input_channels            = ''
    cellpose_norm_percentile           = '1 99'
    cellpose_niter                     = 0
    cellpose_stitch_threshold          = 0.0
    cellprob_threshold                 = 1.0
    cellpose_flow3D_smooth             = 1.0
    cellpose_labels_distance_th        = 1.0

    cellpose_preprocessing_steps       = ''
    cellpose_preprocessing_config_file = ''

    cellpose_segmentation_cpus         = 1
    cellpose_segmentation_mem_gb       = 0

    cellpose_mergelabels_cpus          = 1
    cellpose_mergelabels_mem_gb        = 0

    cellpose_dask_workers              = 8
    cellpose_dask_min_workers          = 1
    cellpose_dask_worker_cpus          = 1
    cellpose_dask_worker_mem_gb        = 0
    cellpose_dask_worker_threads       = 1

    cellpose_scheduler_port            = 0
    cellpose_dashboard_port            = 0

    cellpose_driver_runtime_opts       = ''
    cellpose_driver_cluster_opts       = ''
    cellpose_worker_runtime_opts       = ''
    cellpose_worker_cluster_opts       = ''
}

process {

    withName: "(.*):SEGMENTATION:(.*)" {
        container = 'ghcr.io/janeliascicomp/cellpose:4.0.8-dask2025.11.0-py12'
        containerOptions = params.runtime_opts
        errorStrategy = 'terminate'
        time = 48.h
    }

    withName: "(.*):SEGMENTATION:(.*)DASK_STARTMANAGER" {
        containerOptions = params.runtime_opts
        ext.args = [
            "--port ${params.cellpose_scheduler_port}",
            "--dashboard-address ${params.cellpose_dashboard_port}",
        ].join(' ')
    }

    withName: "(.*):SEGMENTATION:(.*)DASK_STARTWORKER" {
        containerOptions = "${params.runtime_opts} ${params.cellpose_worker_runtime_opts}"
        clusterOptions = params.cellpose_worker_cluster_opts
        ext.args = [
            "--nthreads ${params.cellpose_dask_worker_threads}",
        ].join(' ')
    }

    withName: "(.*):SEGMENTATION:(.*)SEGTOOLS_DISTRIBUTED_CELLPOSE" {
        containerOptions = "${params.runtime_opts} ${params.cellpose_driver_runtime_opts}"
        clusterOptions = params.cellpose_driver_cluster_opts
        ext {
            args = [

                params.segmentation_roi                  ? "--roi ${params.segmentation_roi}"                                 : '',
                params.segmentation_processsize          ? "--process-blocksize ${params.segmentation_processsize}"           : '',
                params.segmentation_process_overlap      ? "--blocks-overlaps ${params.segmentation_process_overlap}"         : '',
                params.segmentation_output_chunksize     ? "--output-blocksize ${params.segmentation_output_chunksize}"       : '',
                params.segmentation_compression          ? "--compressor ${params.segmentation_compression}"                  : '',
                params.segmentation_zarr_format          ? "--zarr-format ${params.segmentation_zarr_format}"                 : '',
                params.segmentation_zarr_sharding_factor ? "--sharding-factor ${params.segmentation_zarr_sharding_factor}"    : '',

                params.segmentation_compression_opts     ? "--compressor-opts ${params.segmentation_compression_opts}"        : '',

                params.cellpose_do_3D                    ? '--do_3D'                                                          : '',

                params.sample_z_axis                     ? "--z_axis ${params.sample_z_axis}"                                 : '',
                params.sample_channel_axis               ? "--channel_axis ${params.sample_channel_axis}"                     : '',

                params.sample_anisotropy                 ? "--anisotropy ${params.sample_anisotropy}"                         : '',
                params.sample_expansion_factor           ? "--expansion-factor ${params.sample_expansion_factor}"             : '',
                params.sample_voxel_spacing              ? "--voxel-spacing ${params.sample_voxel_spacing}"                   : '',
                params.sample_timeindex                  ? "--timeindex ${params.sample_timeindex}"                           : '',
                params.cellpose_input_channels           ? "--input-channels ${params.cellpose_input_channels}"               : '',
                params.cellpose_norm_percentile          ? "--norm_percentile ${params.cellpose_norm_percentile}"             : '',
                params.cellpose_niter                    ? "--niter ${params.cellpose_niter}"                                 : '',
                params.cellpose_stitch_threshold         ? "--stitch_threshold ${params.cellpose_stitch_threshold}"           : '',
                params.cellprob_threshold                ? "--cellprob_threshold ${params.cellprob_threshold}"                : '',
                params.cellpose_flow3D_smooth            ? "--flow3D_smooth ${params.cellpose_flow3D_smooth}"                 : '',
                params.cellpose_diameter                 ? "--diameter ${params.cellpose_diameter}"                           : '',
                params.cellpose_no_resampling            ? '--no_resample'                                                    : '',
                params.cellpose_min_size                 ? "--min_size ${params.cellpose_min_size}"                           : '',
                params.cellpose_device                   ? "--device ${params.cellpose_device}"                               : '',
                params.cellpose_labels_distance_th       ? "--label-distance-threshold ${params.cellpose_labels_distance_th}" : '',
                params.cellpose_inference_batch_size     ? "--batch_size ${params.cellpose_inference_batch_size}"             : '',

                params.cellpose_preprocessing_steps      ? "--preprocessing-steps ${params.cellpose_preprocessing_steps}"     : '',

                params.cellpose_use_gpu                  ? '--use_gpu'                                                        : '',

                params.cellpose_dask_workers             ? "--local-dask-workers ${params.cellpose_dask_workers}"             : '',
                params.cellpose_dask_worker_cpus         ? "--worker-cpus ${params.cellpose_dask_worker_cpus}"                : '',

                (params.skip_cellpose_merge_labels || params.run_standalone_merge_labels) ? '--skip-merge-labels'             : '',
                params.cellpose_verbose                  ? '--verbose'                                                        : '',
            ].join(' ')
        }
    }

    withName: "(.*):SEGMENTATION:(.*)SEGTOOLS_DISTRIBUTED_MERGELABELS" {
        containerOptions = "${params.runtime_opts} ${params.cellpose_driver_runtime_opts}"
        clusterOptions = params.cellpose_driver_cluster_opts
        ext {
            args = [
                params.segmentation_roi                  ? "--roi ${params.segmentation_roi}"                                 : '',
                params.segmentation_processsize          ? "--process-blocksize ${params.segmentation_processsize}"     : '',
                params.segmentation_compression          ? "--compressor ${params.segmentation_compression}"                  : '',
                params.segmentation_compression_opts     ? "--compressor-opts ${params.segmentation_compression_opts}"        : '',
                params.segmentation_zarr_format          ? "--zarr-format ${params.segmentation_zarr_format}"                 : '',
                params.segmentation_zarr_sharding_factor ? "--sharding-factor ${params.segmentation_zarr_sharding_factor}"    : '',

                params.cellpose_labels_distance_th       ? "--label-distance-threshold ${params.cellpose_labels_distance_th}" : '',

                params.cellpose_dask_workers             ? "--local-dask-workers ${params.cellpose_dask_workers}"             : '',
                params.cellpose_dask_worker_cpus         ? "--worker-cpus ${params.cellpose_dask_worker_cpus}"                : '',

                params.cellpose_verbose                  ? '--verbose'                                                        : '',
            ].join(' ')
        }
    }

}
