params {
    runtime_opts                          = ''

    spot_extraction_ids                   = ''

    skip_spot_extraction                  = false
    skipped_spot_extraction_rounds        = ''
    extract_spots_from_warped             = false
    spot_extraction_method                = 'RS_FISH'

    distributed_spot_extraction           = true
    spot_extraction_subdir                = 'spots'
    spot_channels                         = ''
    spot_excluded_channels                = ''
    spot_scales                           = ''
    spot_subpaths                         = '0'
    spots_image_name                      = ''
    spots_image_subpath_ref               = ''

    rsfish_min_intensity                  = '0'
    rsfish_max_intensity                  = '4096'
    rsfish_anisotropy                     = '0.7'
    rsfish_sigma                          = '1.5'
    rsfish_threshold                      = '0.007'
    rsfish_background                     = '0'
    rsfish_intensity_th                   = '0'
    rsfish_intensity_method               = '0'

    // RS-FISH spark resources
    rsfish_spark_workers                  = 1
    rsfish_min_spark_workers              = 1
    rsfish_spark_worker_cores             = 5
    rsfish_spark_worker_mem_gb            = 0
    rsfish_spark_executor_cores           = 5
    rsfish_spark_executor_mem_gb          = 0
    rsfish_spark_executor_overhead_mem_gb = 1
    rsfish_spark_driver_cores             = 1
    rsfish_spark_driver_mem_gb            = 0
    rsfish_spark_task_cores               = 1
    rsfish_spark_max_partition_bytes      = ''
    rsfish_spark_gb_per_core              = 15

    fishspots_psf_file                    = ''
    fishspots_psf_retries                 = 3
    fishspots_psf_trim                    = 4
    fishspots_intensity_threshold         = 0
    fishspots_intensity_threshold_minimum = 0
    fishspots_config                      = "${projectDir}/conf/fishspots_config.yml"
    fishspots_dask_config                 = "${projectDir}/conf/dask_config.yml"
    fishspots_blocksize                   = '128,128,128'
    fishspots_verbose                     = false
    // FISHSPOTS dask resources
    fishspots_dask_workers                = 1
    fishspots_dask_min_workers            = 1
    fishspots_dask_worker_cpus            = 1
    fishspots_dask_worker_mem_gb          = 4
    fishspots_local_workers               = 0
    fishspots_dask_nthreads               = 1
    fishspots_dask_nprocs                 = 1
    fishspots_cpus                        = 1
    fishspots_mem_gb                      = 0
}

process {

    withName: "(.*)?SPOT_EXTRACTION:SPARK.*" {
        // set container for all spark tasks
        container = 'ghcr.io/janeliascicomp/rs-fish-spark:omedev'
        errorStrategy = 'terminate'
    }

    withName: "(.*)?SPOT_EXTRACTION:(.*)SPOTS_RSFISH" {
        errorStrategy = 'terminate'
        container = 'ghcr.io/janeliascicomp/rs-fish-spark:omedev'
        ext.args = [
            optional_arg_sep_value('--included-channels', params.spot_channels, '='),
            optional_arg_sep_value('--excluded-channels', params.spot_excluded_channels, '='),
            rsfish_args(params),
        ].join(' ')
    }

    withName: "(.*)?SPOT_EXTRACTION:(.*)DASK.*" {
        // set container for all dask tasks
        container = 'ghcr.io/janeliascicomp/easifish-spots-utils:v1.2-ome-dask2025.11.0'
        errorStrategy = 'terminate'
    }

    withName: "(.*)?SPOT_EXTRACTION:(.*)DASK_STARTMANAGER" {
        container = 'ghcr.io/janeliascicomp/easifish-spots-utils:v1.2-ome-dask2025.11.0'

        ext {
            args = [
                "--port 0",
                "--dashboard-address 0",
            ].join(' ')
        }
    }

    withName: "(.*)?SPOT_EXTRACTION:(.*)DASK_STARTWORKER" {
        container = 'ghcr.io/janeliascicomp/easifish-spots-utils:v1.2-ome-dask2025.11.0'

        ext {
            args = [
                optional_arg_value('--nthreads', params.fishspots_dask_nthreads),
                optional_arg_value('--nworkers', params.fishspots_dask_nprocs),
            ].join(' ')
        }
    }

    withName: "(.*)?SPOT_EXTRACTION:(.*)SPOTS_FISHSPOTS" {
        // set container for all dask tasks
        container = 'ghcr.io/janeliascicomp/easifish-spots-utils:v1.2-ome-dask2025.11.0'
        errorStrategy = 'terminate'
        time = 24.h
        ext.args = [
            optional_arg_value('--blocksize', params.fishspots_blocksize),
            optional_arg_value('--included-channels', params.spot_channels),
            optional_arg_value('--excluded-channels', params.spot_excluded_channels),
            optional_arg_value('--psf-file', params.fishspots_psf_file),
            optional_arg_value('--psf-retries', params.fishspots_psf_retries),
            optional_arg_value('--psf-trim', params.fishspots_psf_trim),
            optional_arg_value('--intensity-threshold', params.fishspots_intensity_threshold),
            optional_arg_value('--intensity-threshold-minimum', params.fishspots_intensity_threshold_minimum),
            optional_arg_value('--local-dask-workers', params.fishspots_local_workers),
            optional_arg_value('--worker-cpus', params.fishspots_dask_worker_cpus),
            optional_arg_value('--output-spots-imagename', params.spots_image_name),
            bool_arg('--verbose', params.fishspots_verbose),
        ].join(' ')
    }

    withName: "(.*)?SPOT_EXTRACTION:POST_RS_FISH" {
        container = 'ghcr.io/janeliascicomp/easifish-spots-utils:v1.2-ome-dask2025.11.0'
        errorStrategy = 'terminate'

        ext.args = [
            optional_arg_value('--expansion-factor', params.volume_expansion),
        ].join(' ')
    }

}

def bool_arg (arg_flag, arg_value) {
    arg_value ? "${arg_flag}" : ''
}

def optional_arg_value (arg_flag, arg_value) {
    arg_value ? "${arg_flag} ${arg_value}" : ''
}

def optional_arg_sep_value (arg_flag, arg_value, sep) {
    def arg_value_sep = sep ?: ' '
    arg_value ? "${arg_flag}${arg_value_sep}${arg_value}" : ''
}

// RS-FISH arguments builder
def rsfish_args (ps) {
    // typically these parameters are numeric
    // if any is a string try to get a list of comma separated values
    // the first value in the list is the default value for all channels
    def min_intensity = ps.rsfish_min_intensity.split(',')
    def max_intensity = ps.rsfish_max_intensity.split(',')
    def anisotropy = ps.rsfish_anisotropy.split(',')
    def sigma = ps.rsfish_sigma.split(',')
    def threshold = ps.rsfish_threshold.split(',')
    def background = ps.rsfish_background.split(',')
    def intensityThreshold = ps.rsfish_intensity_th.split(',')
    def intensityMethod = ps.rsfish_intensity_method.split(',')

    def n_rsfish_args = [
        min_intensity.size(),
        max_intensity.size(),
        anisotropy.size(),
        sigma.size(),
        threshold.size(),
        background.size(),
        intensityThreshold.size(),
        intensityMethod.size(),
    ].max()

    def args = []
    (0..<n_rsfish_args).each { c ->
        args << "--for-channel=${c-1}"
        if (c < min_intensity.size()) {
            args << "--minIntensity=${min_intensity[c]}"
        }
        if (c < max_intensity.size()) {
            args << "--maxIntensity=${max_intensity[c]}"
        }
        if (c < anisotropy.size()) {
            args << "--anisotropy=${anisotropy[c]}"
        }
        if (c < sigma.size()) {
            args << "--sigma=${sigma[c]}"
        }
        if (c < threshold.size()) {
            args << "--threshold=${threshold[c]}"
        }
        if (c < background.size()) {
            args << "--background=${background[c]}"
        }
        if (c < intensityThreshold.size()) {
            args << "--intensityThreshold=${intensityThreshold[c]}"
        }
        if (c < intensityMethod.size()) {
            args << "--intensityMethod=${intensityMethod[c]}"
        }
    }
    args.join(' ')
}
