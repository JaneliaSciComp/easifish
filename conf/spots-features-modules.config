params {
    spots_props_cores              = 1
    spots_props_mem_gb             = 0
    spots_timeindex                = ''
    labels_timeindex               = ''
    labels_channel                 = ''
    spots_props_subdir             = 'spots-props'
    skip_spots_properties          = false
    dapi_channel                   = ''
    bleeding_channel               = ''
    spots_props_process_blocksize  = ''
}

process {

    withName: "(.*)?SPOTS_PROPS" {
        container = 'ghcr.io/janeliascicomp/easifish-spots-utils:v1.3-ome-dask2025.11.0'
        time = 48.h

        ext.args = [
            optional_arg_value('--expansion-factor', params.volume_expansion),

            optional_arg_value('--labels-timeindex', params.labels_timeindex),
            optional_arg_value('--labels-channel', params.labels_channel),

            optional_arg_value('--image-timeindex', params.spots_timeindex),
            optional_arg_value('--worker-cpus', params.spots_props_cores),
            optional_arg_value('--processing-blocksize', params.spots_props_process_blocksize),
        ].join(' ')
    }
}

def optional_arg_value (arg_flag, arg_value) {
    arg_value ? "${arg_flag} ${arg_value}" : ''
}
