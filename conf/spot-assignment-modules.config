params {
    spots_counts_cores             = 1
    spots_counts_mem_gb            = 0
    spots_counts_workers           = 1
    spots_counts_worker_cores      = 1
    spots_counts_pattern           = '*coord*.csv'
    spots_counts_subdir            = 'spots-counts'
    labels_timeindex               = ''
    labels_channel                 = ''
    run_spots_counts               = false
    spots_with_labels_output       = '' // output filename for spots with labels result
    spots_counts_process_blocksize = ''
}

process {

    withName: "(.*)?SPOTS_COUNTS" {
        container = 'ghcr.io/janeliascicomp/easifish-spots-utils:v1.3-ome-dask2025.11.0'
        time = 48.h

        ext.args = [
            params.spots_counts_workers           ? "--local-dask-workers ${params.spots_counts_workers}"           : '',
            params.spots_counts_worker_cores      ? "--worker-cpus ${params.spots_counts_worker_cores}"             : '',
            params.volume_expansion               ? "--expansion-factor ${params.volume_expansion}"                 : '',
            params.labels_timeindex               ? "--timeindex ${params.labels_timeindex}"                        : '',
            params.labels_channel                 ? "--channel ${params.labels_channel}"                            : '',
            params.spots_counts_process_blocksize ? "--processing-blocksize ${params.spots_counts_process_blocksize}" : '',
            params.spots_with_labels_output       ? "--labeled-spots-output ${params.spots_with_labels_output}"     : '',
        ].join(' ')
    }

}
