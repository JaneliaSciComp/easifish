/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Runtime environment configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Environment variables exported to all container processes
----------------------------------------------------------------------------------------
*/

env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
    USER             = System.getProperty("user.name")
    MPLCONFIGDIR     = "${System.getenv('TMPDIR') ?: '/tmp'}/matplotlib-config"
    TORCH_HOME       = "${System.getenv('TMPDIR') ?: '/tmp'}/torch-cache"
}
