params {
    runtime_opts                       = ''

    registration_fix_id                = ''
    reg_ch                             = ''
    bigstream_config                   = "${projectDir}/conf/bigstream_config.yml"
    bigstream_verbose                  = false
    registration_compression           = 'zstd'
    registration_compression_opts      = '{\\"level\\":5}'

    // parameters used for determining the global affine
    global_steps                       = 'affine'
    global_scale                       = ''
    fix_global_subpath                 = ''
    fix_global_timeindex               = ''
    fix_global_channel                 = ''
    mov_global_subpath                 = ''
    mov_global_timeindex               = ''
    mov_global_channel                 = ''

    fix_mask                           = ''
    fix_mask_subpath                   = ''
    mov_mask                           = ''
    mov_mask_subpath                   = ''

    // generate foreground masks using bigstream (shared for global and local alignment)
    generate_fix_mask                  = false
    generate_mov_mask                  = false
    foreground_mask_cpus               = 1
    foreground_mask_mem_gb             = 0

    global_results_subdir              = 'global'
    global_registration_container      = 'global-registration.zarr'
    global_registration_timeindex      = ''
    global_transform_name              = 'global-affine.mat'
    global_inv_transform_name          = 'inv-global-affine.mat'
    reuse_global_affine                = true

    // initial transformation applied to global registration
    global_mov_origin_transform        = ''
    // list of static transforations applied to global registration
    global_static_transforms           = ''

    // parameters used for determining the local deformation
    local_scale                        = ''
    fix_local_subpath                  = ''
    fix_local_timeindex                = ''
    fix_local_channel                  = ''
    mov_local_subpath                  = ''
    mov_local_timeindex                = ''
    mov_local_channel                  = ''



    mask_subsampling                   = 2
    mask_lambda                        = 2.5
    mask_smoothing                     = 1
    mask_smooth_sigmas                 = "4"
    mask_thresh_percentile             = 0

    // local masks as min,max voxel coords
    local_fix_roi                      = ''
    local_mov_roi                      = ''

    // initial transformation applied to local registration
    local_mov_origin_transform         = ''
    // list of static transforations applied to local registration
    local_static_transforms            = ''

    registration_subdir                = 'registration'
    local_results_subdir               = 'local'
    local_registration_container       = 'registration.zarr'
    local_registration_timeindex       = ''
    local_steps                        = 'affine,deform'
    distributed_bigstream              = true
    dask_config                        = "${projectDir}/conf/dask_config.yml"
    deform_subpath                     = ''
    local_transform_name               = 'deform.zarr'
    local_inv_transform_name           = 'inv-deform.zarr'
    warped_subpaths                    = ''
    warped_channels                    = ''
    warped_scales                      = ''

    bigstream_local_blocksize          = '' // local alignment process size [X,Y,Z]
    bigstream_local_fg_pct             = 0.1
    bigstream_local_overlap_factor     = 0.125
    bigstream_local_deform_overlap     = 0.125
    bigstream_local_inv_overlap_factor = 0.25

    bigstream_deform_blocksize         = '' // local deformation field chunk size [X,Y,Z]
    bigstream_align_blocksize          = '' // block size for applying the deformation as well as warped image chunksize [X,Y,Z]

    bigstream_inv_step                 = 1.0
    bigstream_inv_iterations           = '20'
    bigstream_inv_shrink_spacings      = ''
    bigstream_inv_smooth_sigmas        = '0.'
    bigstream_inv_step_cut_factor      = 0.5
    bigstream_inv_pad                  = 0.1
    bigstream_inv_use_root             = true

    skip_registration                  = false
    skip_global_align                  = false
    skip_local_align                   = false

    // correlation metric (optional, runs after global and/or local registration)
    run_global_metric                  = false
    run_local_metric                   = false
    global_correlation_container       = 'correlation-metric.zarr'
    global_correlation_output_subpath  = ''

    local_correlation_container        = 'correlation-metric.zarr'
    local_correlation_input_subpath    = ''
    local_correlation_output_subpath   = ''

    neighborhood_for_metric_eval       = 3

    skip_deformations                  = false
    skip_inverse                       = false
    run_warped_multiscale              = false

    global_align_cpus                  = 3
    global_align_mem_gb                = 0
    local_align_cpus                   = 1
    local_align_mem_gb                 = 0
    local_inverse_cpus                 = 1
    local_inverse_mem_gb               = 0
    local_deform_cpus                  = 1
    local_deform_mem_gb                = 0

    bigstream_dask_workers             = 10
    bigstream_dask_min_workers         = 1
    bigstream_dask_worker_cpus         = 1
    bigstream_dask_worker_mem_gb       = 0
    bigstream_worker_retry             = false
    bigstream_worker_max_retries       = 1
    bigstream_dask_nthreads            = 1
    bigstream_dask_nprocs              = 0
    bigstream_scheduler_port           = 0
    bigstream_dashboard_port           = 0
    bigstream_max_concurrent_reads     = 0
}

process {

    withName: "(.*):REGISTRATION:(.*)" {
        container = 'ghcr.io/janeliascicomp/bigstream:5.1.4-omezarr-dask2025.11.0-py12-ol9'
        containerOptions = "${params.runtime_opts}"
        errorStrategy = 'terminate'
        time = 48.h
    }

    withName: "(.*):REGISTRATION:(.*)DASK_STARTMANAGER" {
        container = 'ghcr.io/janeliascicomp/bigstream:5.1.4-omezarr-dask2025.11.0-py12-ol9'
        containerOptions = params.runtime_opts

        ext {
            args = [
                "--port ${params.bigstream_scheduler_port}",
                "--dashboard-address ${params.bigstream_dashboard_port}",
            ].join(' ')
        }
    }

    withName: "(.*):REGISTRATION:(.*)DASK_STARTWORKER" {
        container = 'ghcr.io/janeliascicomp/bigstream:5.1.4-omezarr-dask2025.11.0-py12-ol9'
        errorStrategy = { params.bigstream_worker_retry && task.exitStatus in [130, 137] ? 'retry' : 'terminate' }
        maxRetries = { params.bigstream_worker_max_retries }

        ext {
            args = [
                optional_arg_value('--nthreads', params.bigstream_dask_nthreads),
                optional_arg_value('--nworkers', params.bigstream_dask_nprocs),
            ].join(' ')
        }
    }

    withName: "(.*):REGISTRATION:(.*)BIGSTREAM_GLOBALALIGN" {
        ext {
            args = [
                optional_arg_value('--global-mov-origin-transform', params.global_mov_origin_transform),
                optional_arg_value('--global-static-transforms', params.global_static_transforms),

                optional_arg_value('--global-fix-expansion', params.volume_expansion),
                optional_arg_value('--global-mov-expansion', params.volume_expansion),

                optional_arg_value('--cpus', params.global_align_cpus),

                bool_arg('--reuse-existing-transform', params.reuse_global_affine),

                optional_arg_value('--compressor', params.registration_compression),
                optional_arg_value('--compressor-opts', params.registration_compression_opts),

                bool_arg('--verbose', params.bigstream_verbose),
            ].join(' ')
        }
    }

    withName: "(.*):REGISTRATION:(.*)BIGSTREAM_LOCALALIGN" {
        ext {
            args = [
                optional_arg_value('--local-fix-expansion', params.volume_expansion),
                optional_arg_value('--local-mov-expansion', params.volume_expansion),

                optional_arg_value('--local-fix-roi', params.local_fix_roi),
                optional_arg_value('--local-mov-roi', params.local_mov_roi),

                optional_arg_value('--local-mov-origin-transform', params.local_mov_origin_transform),
                optional_arg_value('--local-static-transforms', params.local_static_transforms),

                optional_arg_value('--foreground-percentage', params.bigstream_local_fg_pct),

                optional_arg_value('--local-processing-size', params.bigstream_local_blocksize),
                optional_arg_value('--local-processing-overlap-factor', params.bigstream_local_overlap_factor),

                optional_arg_value('--local-transform-blocksize', params.bigstream_deform_blocksize),

                optional_arg_value('--local-dask-workers', params.bigstream_dask_workers),
                optional_arg_value('--worker-cpus', params.bigstream_dask_worker_cpus),

                optional_arg_value('--compressor', params.registration_compression),
                optional_arg_value('--compressor-opts', params.registration_compression_opts),

                optional_arg_value('--max-concurrent-zarr-reads', params.bigstream_max_concurrent_reads),

                bool_arg('--verbose', params.bigstream_verbose),
            ].join(' ')
        }
    }

    withName: "(.*):REGISTRATION:(.*)BIGSTREAM_DEFORM" {
        ext {
            args = [
                optional_arg_value('--fix-expansion', params.volume_expansion),
                optional_arg_value('--mov-expansion', params.volume_expansion),
                optional_arg_value('--local-transform-expansion', params.volume_expansion),

                optional_arg_value('--static-transforms', params.local_static_transforms),

                optional_arg_value('--output-blocksize', params.bigstream_align_blocksize),
                optional_arg_value('--blocks-overlap-factor', params.bigstream_local_deform_overlap),

                optional_arg_value('--local-dask-workers', params.bigstream_dask_workers),
                optional_arg_value('--worker-cpus', params.bigstream_dask_worker_cpus),

                optional_arg_value('--compressor', params.registration_compression),
                optional_arg_value('--compressor-opts', params.registration_compression_opts),

                optional_arg_value('--max-concurrent-zarr-reads', params.bigstream_max_concurrent_reads),

                bool_arg('--verbose', params.bigstream_verbose),
            ].join(' ')
        }
    }

    withName: "(.*):REGISTRATION:(.*)BIGSTREAM_COMPUTEINVERSE" {
        ext {
            args = [
                optional_arg_value('--processing-overlap-factor', params.bigstream_local_inv_overlap_factor),
                optional_arg_value('--local-transform-expansion', params.volume_expansion),

                // parameters for generating the inverse transform
                optional_arg_value('--inv-step', params.bigstream_inv_step),
                optional_arg_value('--inv-iterations', params.bigstream_inv_iterations),
                optional_arg_value('--inv-shrink-spacings', params.bigstream_inv_shrink_spacings),
                optional_arg_value('--inv-smooth-sigmas', params.bigstream_inv_smooth_sigmas),
                optional_arg_value('--inv-step-cut-factor', params.bigstream_inv_step_cut_factor),
                optional_arg_value('--inv-pad', params.bigstream_inv_pad),
                bool_arg('--inv-use-root', params.bigstream_inv_use_root),

                optional_arg_value('--local-dask-workers', params.bigstream_dask_workers),
                optional_arg_value('--worker-cpus', params.bigstream_dask_worker_cpus),

                optional_arg_value('--compressor', params.registration_compression),
                optional_arg_value('--compressor-opts', params.registration_compression_opts),

                optional_arg_value('--max-concurrent-zarr-reads', params.bigstream_max_concurrent_reads),

                bool_arg('--verbose', params.bigstream_verbose),
            ].join(' ')
        }
    }

    withName: "(.*):REGISTRATION:(.*)BIGSTREAM_FOREGROUNDMASK.*" {
        cpus = params.foreground_mask_cpus ?: 1
        memory = "${params.foreground_mask_mem_gb ?: 1} GB"
        containerOptions = "${params.runtime_opts}"
        errorStrategy    = 'terminate'
        ext {
            args = [
                optional_arg_value('--mask-subsampling', params.mask_subsampling),
                optional_arg_value('--mask-lambda', params.mask_lambda),
                optional_arg_value('--mask-smoothing', params.mask_smoothing),
                optional_arg_value('--mask-smooth-sigmas', params.mask_smooth_sigmas),
                optional_arg_value('--mask-threshold-percentile', params.mask_thresh_percentile),

                bool_arg('--verbose', params.bigstream_verbose),
            ].join(' ')
        }
    }

    withName: "(.*):REGISTRATION:(.*)BIGSTREAM_CORRELATIONMETRIC" {
        ext {
            args = [
                optional_arg_value('--radius', params.neighborhood_for_metric_eval),
                bool_arg('--verbose', params.bigstream_verbose),
            ].join(' ')
        }
    }

}

// Utility closures for building command arguments
def bool_arg (arg_flag, arg_value) {
    arg_value ? "${arg_flag}" : ''
}

def optional_arg_value (arg_flag, arg_value) {
    arg_value ? "${arg_flag} ${arg_value}" : ''
}
