{
    "channels": "c0,c1",
    "input": "${projectDir}/examples/samplesheets/tiny_samplesheet.csv",

    "run_stitching": true,
    "run_registration": true,
    "run_global_align": true,
    "run_local_align": true,
    "run_deformations": true,
    "run_inverse": true,
    "run_segmentation": true,
    "run_spot_extraction": true,
    "run_warp_spots": true,

    "flatfield_correction": false,
    "darkfieldfile": "",
    "flatfieldfile": "",

    "registration_fix_id": "t1",
    "stitching_channel": "c1",
    "reg_ch": "c1",
    "global_steps": "ransac,affine",
    "local_steps": "ransac,affine,deform",
    "global_scale": "s3",
    "local_scale": "s2",
    "warped_scales": "s0",

    "cellpose_test": false,
    "cellpose_verbose": true,
    "cellpose_dask_workers": 4,
    "cellpose_dask_worker_cpus": 1,
    "cellpose_merge_with_iou_only": false,
    "cellpose_worker_runtime_opts": "--nv",

    "spark_workers": 5,
    "min_spark_workers": 2,
    "spark_gb_per_core": 8,

    "bigstream_dask_workers": 10,
    "bigstream_dask_worker_mem_gb": 10,
    "bigstream_scheduler_port": 0,
    "bigstream_dashboard_port": 0,

    "multiscale_spark_workers": 1,
    "multiscale_spark_worker_cores": 20,
    "multiscale_spark_gb_per_core": 5,

    "dapi_channel": "c1",
    "bleeding_channel": "c0",

    "lsf_opts": "-P scicompsoft",
    "cellpose_worker_cluster_opts": "-P scicompsoft -q gpu_l4 -gpu 'num=1'",
    "singularity_cache_dir": "/nrs/scicompsoft/nextflow_work/.singularity_cache"
}
